# Copy to .env at the repo root: cp .env.example .env

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://medieval:medieval@localhost:5433/medieval_empires

# API server
PORT=8080

# Expo mobile app — base URL for API requests (no trailing slash)
# Dev: localhost is rewritten automatically on Android (→ 10.0.2.2 or your Metro LAN IP)
# iOS Simulator / web: http://localhost:8080
# Android emulator (manual): http://10.0.2.2:8080
# Physical device (manual): http://<your-lan-ip>:8080
EXPO_PUBLIC_API_URL=http://localhost:8080

# Replit-only (leave unset for local development)
# EXPO_PUBLIC_DOMAIN=
